{
  "expo": {
    "name": "OIAC Prayer",
    "slug": "oiac-prayer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "oiac-prayer",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#5C1A1B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ca.oiacedmonton.prayer"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5C1A1B"
      },
      "edgeToEdgeEnabled": true,
      "package": "ca.oiacedmonton.prayer",
      "permissions": ["SCHEDULE_EXACT_ALARM"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "sounds": [],
          "android": {
            "channelId": "prayer-times",
            "channelName": "Prayer Times",
            "channelDescription": "Notifications for OIAC prayer times",
            "importance": 4,
            "enableVibrate": true
          }
        }
      ]
    ]
  }
}
